# Optional. Next.js auto-loads this from .env.local / .env.
# If omitted, the app defaults to ~/.openclaw when it exists.
# If neither this path nor ~/.openclaw exists, the app falls back to demo/openclaw-home.
OPENCLAW_HOME=~/.openclaw

# Local frontend bind address used by `pnpm dev` and `pnpm start`.
# Change the port if another local app already uses it.
DASHBOARD_URL=http://localhost:3000
