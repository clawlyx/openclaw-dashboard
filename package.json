{
  "name": "openclaw-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "OpenClaw workstation for agents, mission control, usage, provider limits, and scheduler health.",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "node scripts/next-runner.mjs dev",
    "build": "next build",
    "start": "node scripts/next-runner.mjs start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "typescript": "latest"
  }
}
